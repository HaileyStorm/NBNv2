<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Nbn.Tools.Workbench.ViewModels"
             x:Class="Nbn.Tools.Workbench.Views.Panels.OrchestratorPanel"
             x:DataType="vm:OrchestratorPanelViewModel">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="16">
      <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
        <Border Classes="card" Grid.Column="0">
          <StackPanel Spacing="10">
            <TextBlock Text="Settings Discovery" Classes="card-title" />
            <TextBlock Text="Use these coordinates when SettingsMonitor was launched externally. All other endpoint identities are discovered from SettingsMonitor." Classes="muted" TextWrapping="Wrap" />
            <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="8">
              <TextBox Text="{Binding Connections.SettingsHost}" Width="160" />
              <TextBox Grid.Column="1" Text="{Binding Connections.SettingsPortText}" Width="90" />
              <TextBox Grid.Column="2" Text="{Binding Connections.SettingsName}" Width="140" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Classes="card" Grid.Column="1">
          <StackPanel Spacing="10">
            <TextBlock Text="Endpoints" Classes="card-title" />
            <TextBlock Text="Core service discovery status. Missing services remain visible as offline chips." Classes="muted" TextWrapping="Wrap" />
            <ItemsControl ItemsSource="{Binding Endpoints}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Columns="2" Rows="3" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="row" Margin="4">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                      <Border Classes="pill"
                              Background="{Binding StatusChipBackground}"
                              BorderBrush="{Binding StatusChipBorder}"
                              BorderThickness="1">
                        <TextBlock Text="{Binding Status}" Foreground="{Binding StatusChipForeground}" />
                      </Border>
                      <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding ServiceName}" Classes="row-title" />
                        <TextBlock Text="{Binding EndpointDisplay}" Classes="muted" TextWrapping="Wrap" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </Grid>

      <Border Classes="card">
        <StackPanel Spacing="8">
          <TextBlock Text="Local Launch" Classes="card-title" />
          <TextBlock Text="Services start only from Start/Start All; connection attempts do not auto-launch runtimes." Classes="muted" TextWrapping="Wrap" />
          <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="14" RowSpacing="6">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Start All" Command="{Binding StartAllCommand}" Classes="accent" />
              <Button Content="Stop All" Command="{Binding StopAllCommand}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
              <Button Content="Spawn Sample Brain" Command="{Binding SpawnSampleBrainCommand}" Classes="accent" />
              <Button Content="Stop Sample Brain" Command="{Binding StopSampleBrainCommand}" />
              <TextBlock Text="{Binding SampleBrainStatus}" Classes="muted" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
              <Button Content="Profile Current System" Command="{Binding ProfileCurrentSystemCommand}" />
              <TextBlock Text="{Binding ProfileCurrentSystemStatus}" Classes="muted" VerticalAlignment="Center" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Grid.Column="1" Grid.RowSpan="3" Spacing="4" VerticalAlignment="Top">
              <CheckBox Content="Workbench logging" IsChecked="{Binding Connections.WorkbenchLoggingEnabled}" />
              <TextBlock Text="{Binding Connections.WorkbenchLogPath}" Classes="muted" TextWrapping="Wrap" MaxWidth="260" />
            </StackPanel>
          </Grid>
          <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6">
              <TextBlock Text="SettingsMonitor" Classes="muted" />
              <TextBox Grid.Column="1" Text="{Binding Connections.SettingsPortText}" Width="90" />
              <Button Grid.Column="2" Content="Start" Command="{Binding StartSettingsMonitorCommand}" Classes="accent" />
              <Button Grid.Column="3" Content="Stop" Command="{Binding StopSettingsMonitorCommand}" />
              <TextBlock Grid.Column="4" Text="{Binding SettingsLaunchStatus}" Classes="muted" VerticalAlignment="Center" />

              <TextBlock Grid.Row="1" Text="HiveMind" Classes="muted" />
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Connections.HiveMindPortText}" Width="90" />
              <Button Grid.Row="1" Grid.Column="2" Content="Start" Command="{Binding StartHiveMindCommand}" Classes="accent" />
              <Button Grid.Row="1" Grid.Column="3" Content="Stop" Command="{Binding StopHiveMindCommand}" />
              <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding HiveMindLaunchStatus}" Classes="muted" VerticalAlignment="Center" />

              <TextBlock Grid.Row="2" Text="IO Gateway" Classes="muted" />
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Connections.IoPortText}" Width="90" />
              <Button Grid.Row="2" Grid.Column="2" Content="Start" Command="{Binding StartIoCommand}" Classes="accent" />
              <Button Grid.Row="2" Grid.Column="3" Content="Stop" Command="{Binding StopIoCommand}" />
              <TextBlock Grid.Row="2" Grid.Column="4" Text="{Binding IoLaunchStatus}" Classes="muted" VerticalAlignment="Center" />

              <TextBlock Grid.Row="3" Text="Worker Node" Classes="muted" />
              <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Connections.WorkerPortText}" Width="90" />
              <Button Grid.Row="3" Grid.Column="2" Content="Start" Command="{Binding StartWorkerCommand}" Classes="accent" />
              <Button Grid.Row="3" Grid.Column="3" Content="Stop" Command="{Binding StopWorkerCommand}" />
              <TextBlock Grid.Row="3" Grid.Column="4" Text="{Binding WorkerLaunchStatus}" Classes="muted" VerticalAlignment="Center" />

              <TextBlock Grid.Row="4" Text="Limits %" Classes="muted" />
              <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Vertical" Spacing="2" Margin="-4,0,0,0">
                <StackPanel Orientation="Horizontal" Spacing="3">
                  <TextBlock Text="C" Classes="muted" VerticalAlignment="Center" />
                  <TextBox Text="{Binding Connections.WorkerCpuLimitPercentText}" Width="24" />
                  <TextBlock Text="R" Classes="muted" VerticalAlignment="Center" />
                  <TextBox Text="{Binding Connections.WorkerRamLimitPercentText}" Width="24" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="3">
                  <TextBlock Text="G" Classes="muted" VerticalAlignment="Center" />
                  <TextBox Text="{Binding Connections.WorkerGpuLimitPercentText}" Width="24" />
                  <TextBlock Text="V" Classes="muted" VerticalAlignment="Center" />
                  <TextBox Text="{Binding Connections.WorkerVramLimitPercentText}" Width="24" />
                </StackPanel>
              </StackPanel>
            </Grid>

            <Grid Grid.Column="1" ColumnDefinitions="Auto,Auto,Auto,Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6">
              <TextBlock Text="Reproduction" Classes="muted" />
              <TextBox Grid.Column="1" Text="{Binding Connections.ReproPortText}" Width="90" />
              <Button Grid.Column="2" Content="Start" Command="{Binding StartReproCommand}" Classes="accent" />
              <Button Grid.Column="3" Content="Stop" Command="{Binding StopReproCommand}" />
              <TextBlock Grid.Column="4" Text="{Binding ReproLaunchStatus}" Classes="muted" VerticalAlignment="Center" />

              <TextBlock Grid.Row="1" Text="Speciation" Classes="muted" />
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Connections.SpeciationPortText}" Width="90" />
              <Button Grid.Row="1" Grid.Column="2" Content="Start" Command="{Binding StartSpeciationCommand}" Classes="accent" />
              <Button Grid.Row="1" Grid.Column="3" Content="Stop" Command="{Binding StopSpeciationCommand}" />
              <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding SpeciationLaunchStatus}" Classes="muted" VerticalAlignment="Center" />

              <TextBlock Grid.Row="2" Text="Observability" Classes="muted" />
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Connections.ObsPortText}" Width="90" />
              <Button Grid.Row="2" Grid.Column="2" Content="Start" Command="{Binding StartObsCommand}" Classes="accent" />
              <Button Grid.Row="2" Grid.Column="3" Content="Stop" Command="{Binding StopObsCommand}" />
              <TextBlock Grid.Row="2" Grid.Column="4" Text="{Binding ObsLaunchStatus}" Classes="muted" VerticalAlignment="Center" />
            </Grid>
          </Grid>
        </StackPanel>
      </Border>

      <StackPanel Spacing="16">
        <Border Classes="card">
          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
              <TextBlock Text="Worker Policy" Classes="card-title" />
              <Button Grid.Column="1" Content="Apply" Command="{Binding ApplyWorkerPolicyCommand}" Classes="accent" />
            </Grid>
            <TextBlock Text="Settings-backed worker capability refresh and pressure-rebalance policy. These values apply even when Workbench is not running."
                       Classes="muted"
                       TextWrapping="Wrap" />
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
              <TextBlock Text="Capability Refresh (s)" Classes="muted" />
              <TextBox Grid.Column="1" Text="{Binding WorkerCapabilityRefreshSecondsText}" Width="100" />
              <TextBlock Grid.Column="2" Text="Pressure Window" Classes="muted" />
              <TextBox Grid.Column="3" Text="{Binding WorkerPressureRebalanceWindowText}" Width="100" />

              <TextBlock Grid.Row="1" Text="Violation Ratio" Classes="muted" />
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding WorkerPressureViolationRatioText}" Width="100" />
              <TextBlock Grid.Row="1" Grid.Column="2" Text="Limit Tolerance %" Classes="muted" />
              <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding WorkerPressureTolerancePercentText}" Width="100" />
            </Grid>
            <TextBlock Text="{Binding WorkerPolicyStatus}" Classes="muted" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
          <Border Classes="card" Grid.Column="0">
            <StackPanel Spacing="8">
              <TextBlock Text="Worker Hosts" Classes="card-title" />
              <TextBlock Text="{Binding WorkerEndpointSummary}" Classes="muted" />
              <ScrollViewer MaxHeight="320" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding WorkerEndpoints}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Classes="row">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                          <Border Classes="pill"
                                  Background="{Binding StatusChipBackground}"
                                  BorderBrush="{Binding StatusChipBorder}"
                                  BorderThickness="1">
                            <TextBlock Text="{Binding Status}" Foreground="{Binding StatusChipForeground}" />
                          </Border>
                          <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding LogicalName}" Classes="row-title" />
                            <TextBlock Text="{Binding Address}" Classes="muted" />
                            <TextBlock Text="{Binding RootActor}" Classes="muted" />
                            <TextBlock Text="{Binding PlacementDetail}" Classes="muted" TextWrapping="Wrap" IsVisible="{Binding HasPlacementDetail}" />
                            <TextBlock Text="{Binding BrainHints, StringFormat='Brains: {0}'}" Classes="muted" TextWrapping="Wrap" />
                          </StackPanel>
                          <TextBlock Grid.Column="2" Text="{Binding LastSeen}" Classes="muted" HorizontalAlignment="Right" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </StackPanel>
          </Border>

          <Border Classes="card" Grid.Column="1">
            <StackPanel Spacing="8">
              <TextBlock Text="Hosted Actors" Classes="card-title" />
              <ScrollViewer MaxHeight="320" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Actors}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Classes="row">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                          <Border Classes="pill"
                                  Background="{Binding StatusChipBackground}"
                                  BorderBrush="{Binding StatusChipBorder}"
                                  BorderThickness="1">
                            <TextBlock Text="{Binding Status}" Foreground="{Binding StatusChipForeground}" />
                          </Border>
                          <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding LogicalName}" Classes="row-title" />
                            <TextBlock Text="{Binding Address}" Classes="muted" />
                            <TextBlock Text="{Binding RootActor}" Classes="muted" />
                          </StackPanel>
                          <TextBlock Grid.Column="2" Text="{Binding LastSeen}" Classes="muted" HorizontalAlignment="Right" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </StackPanel>
          </Border>
        </Grid>

        <Border Classes="card">
          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
              <TextBlock Text="Settings" Classes="card-title" />
              <Button Grid.Column="1" Content="Apply" Command="{Binding ApplySettingsCommand}" Classes="accent" />
            </Grid>
            <TextBlock Text="Includes policy keys exposed in Energy + Plasticity; values stay synced across both surfaces."
                       Classes="muted"
                       TextWrapping="Wrap" />
            <ScrollViewer MaxHeight="380" HorizontalScrollBarVisibility="Disabled">
              <ItemsControl ItemsSource="{Binding Settings}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <UniformGrid Columns="2" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="row" Margin="6,4">
                      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="6">
                        <TextBlock Text="{Binding Key}" Classes="row-title" TextWrapping="Wrap" />
                        <TextBlock Grid.Column="1" Text="{Binding Updated}" Classes="muted" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Value}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </StackPanel>
        </Border>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
