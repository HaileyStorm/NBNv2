<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shapes="clr-namespace:Avalonia.Controls.Shapes;assembly=Avalonia.Controls"
             xmlns:vm="clr-namespace:Nbn.Tools.Workbench.ViewModels"
             x:Class="Nbn.Tools.Workbench.Views.Panels.SpeciationPanel"
             x:DataType="vm:SpeciationPanelViewModel">
  <UserControl.Styles>
    <Style Selector="Expander.cladogram-branch">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="Border.cladogram-node">
      <Setter Property="Background" Value="{DynamicResource NbnSurfaceAltBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource NbnBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="6,5" />
    </Style>
    <Style Selector="TextBlock.cladogram-name">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="TextBlock.cladogram-detail">
      <Setter Property="Foreground" Value="{DynamicResource NbnMutedBrush}" />
      <Setter Property="FontSize" Value="10" />
    </Style>
    <Style Selector="Border.cladogram-role-chip">
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Padding" Value="6,2" />
      <Setter Property="Background" Value="#ECE1C5" />
    </Style>
    <Style Selector="TextBlock.cladogram-role-chip">
      <Setter Property="Foreground" Value="{DynamicResource NbnInkBrush}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
  </UserControl.Styles>
  <UserControl.Resources>
    <DataTemplate x:Key="CladogramNodeTemplate" x:DataType="vm:SpeciationCladogramItem">
      <StackPanel Spacing="4">
        <Expander Classes="cladogram-branch" IsVisible="{Binding HasChildren}" IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
          <Expander.Header>
            <Border Classes="cladogram-node">
              <Grid ColumnDefinitions="5,10,*,Auto" ColumnSpacing="8">
                <Border Grid.Column="0"
                        Background="{Binding Color}"
                        CornerRadius="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch" />
                <Border Grid.Column="1"
                        Width="8"
                        Height="8"
                        CornerRadius="999"
                        Background="{Binding Color}"
                        VerticalAlignment="Center" />
                <StackPanel Grid.Column="2" Spacing="1">
                  <TextBlock Text="{Binding SpeciesDisplayName}" Classes="cladogram-name" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding DetailLabel}" Classes="cladogram-detail" TextWrapping="Wrap" />
                </StackPanel>
                <Border Grid.Column="3" Classes="cladogram-role-chip" VerticalAlignment="Center">
                  <TextBlock Text="{Binding RoleLabel}" Classes="cladogram-role-chip" />
                </Border>
              </Grid>
            </Border>
          </Expander.Header>
          <ItemsControl ItemsSource="{Binding Children}"
                        ItemTemplate="{StaticResource CladogramNodeTemplate}"
                        Margin="16,2,0,0" />
        </Expander>

        <Border Classes="cladogram-node" IsVisible="{Binding IsLeaf}">
          <Grid ColumnDefinitions="5,10,*,Auto" ColumnSpacing="8">
            <Border Grid.Column="0"
                    Background="{Binding Color}"
                    CornerRadius="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" />
            <Border Grid.Column="1"
                    Width="8"
                    Height="8"
                    CornerRadius="999"
                    Background="{Binding Color}"
                    VerticalAlignment="Center" />
            <StackPanel Grid.Column="2" Spacing="1">
              <TextBlock Text="{Binding SpeciesDisplayName}" Classes="cladogram-name" TextWrapping="Wrap" />
              <TextBlock Text="{Binding DetailLabel}" Classes="cladogram-detail" TextWrapping="Wrap" />
            </StackPanel>
            <Border Grid.Column="3" Classes="cladogram-role-chip" VerticalAlignment="Center">
              <TextBlock Text="{Binding RoleLabel}" Classes="cladogram-role-chip" />
            </Border>
          </Grid>
        </Border>
      </StackPanel>
    </DataTemplate>
  </UserControl.Resources>
  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="16">
      <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
        <Border Classes="card" Grid.Column="0">
          <StackPanel Spacing="8">
            <TextBlock Text="Speciation Service" Classes="card-title" />
            <TextBlock Text="Status and epoch management for the discovered speciation service. Service lifecycle controls remain in Orchestrator." Classes="muted" TextWrapping="Wrap" />
            <Border Classes="row">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <Border Classes="pill"
                        Background="{Binding Connections.SpeciationChipBackground}"
                        BorderBrush="{Binding Connections.SpeciationChipBorder}"
                        BorderThickness="1">
                  <TextBlock Text="{Binding Connections.SpeciationStatusLabel}" />
                </Border>
                <StackPanel Grid.Column="1">
                  <TextBlock Text="{Binding Connections.SpeciationEndpointDisplay}" Classes="row-title" />
                  <TextBlock Text="{Binding Connections.SpeciationStatus}" Classes="muted" />
                </StackPanel>
              </Grid>
            </Border>
            <TextBlock Text="{Binding ServiceSummary}" Classes="muted" TextWrapping="Wrap" />
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
              <Border Classes="row">
                <StackPanel Spacing="2">
                  <TextBlock Text="Epoch" Classes="muted" />
                  <TextBlock Text="{Binding CurrentEpochLabel}" Classes="row-title" />
                </StackPanel>
              </Border>
              <Border Classes="row" Grid.Column="1">
                <StackPanel Spacing="2">
                  <TextBlock Text="Memberships" Classes="muted" />
                  <TextBlock Text="{Binding CurrentMembershipCount}" Classes="row-title" />
                </StackPanel>
              </Border>
              <Border Classes="row" Grid.Column="2">
                <StackPanel Spacing="2">
                  <TextBlock Text="Species" Classes="muted" />
                  <TextBlock Text="{Binding CurrentSpeciesCount}" Classes="row-title" />
                </StackPanel>
              </Border>
            </Grid>
            <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
              <TextBlock Text="Delete epoch" Classes="muted" VerticalAlignment="Center" />
              <TextBox Grid.Column="1" Width="110" Watermark="Epoch id" Text="{Binding DeleteEpochText}" />
              <TextBlock Grid.Column="2"
                         Text="Removes one historical epoch. Current epoch cannot be deleted."
                         Classes="muted"
                         VerticalAlignment="Center"
                         TextWrapping="Wrap" />
              <Button Grid.Column="3" Content="{Binding DeleteEpochLabel}" Command="{Binding DeleteEpochCommand}" />
            </Grid>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBlock Text="Delete all epochs when you want to clear speciation history and restart from the current policy state." Classes="muted" TextWrapping="Wrap" />
              <Button Grid.Column="1" Content="{Binding ClearAllHistoryLabel}" Command="{Binding ClearAllHistoryCommand}" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Classes="card" Grid.Column="1">
          <StackPanel Spacing="8">
            <TextBlock Text="Policy Config" Classes="card-title" />
            <TextBlock Text="Settings-backed policy draft. SettingsMonitor changes flow in automatically; applying still uses SpeciationSetConfig with explicit new-epoch confirmation." Classes="muted" TextWrapping="Wrap" />
            <CheckBox Content="Enabled" IsChecked="{Binding ConfigEnabled}" />
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
              <TextBlock Text="Policy version" Classes="muted" />
              <TextBox Grid.Column="1" Text="{Binding PolicyVersion}" />

              <TextBlock Grid.Row="1" Text="Default species id" Classes="muted" />
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DefaultSpeciesId}" />

              <TextBlock Grid.Row="2" Text="Default species name" Classes="muted" />
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DefaultSpeciesDisplayName}" />

              <TextBlock Grid.Row="3" Text="Startup reconcile reason" Classes="muted" />
              <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding StartupReconcileReason}" />
            </Grid>
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
              <StackPanel>
                <TextBlock Text="Match" Classes="muted" />
                <TextBox Text="{Binding LineageMatchThreshold}" Width="84" />
              </StackPanel>
              <StackPanel Grid.Column="1">
                <TextBlock Text="Split" Classes="muted" />
                <TextBox Text="{Binding LineageSplitThreshold}" Width="84" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="Consensus" Classes="muted" />
                <TextBox Text="{Binding ParentConsensusThreshold}" Width="84" />
              </StackPanel>
              <StackPanel Grid.Row="1">
                <TextBlock Text="Hysteresis" Classes="muted" />
                <TextBox Text="{Binding HysteresisMargin}" Width="84" />
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="1">
                <TextBlock Text="Split guard" Classes="muted" />
                <TextBox Text="{Binding LineageSplitGuardMargin}" Width="84" />
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="2">
                <TextBlock Text="Min split parents" Classes="muted" />
                <TextBox Text="{Binding LineageMinParentMembershipsBeforeSplit}" Width="112" />
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="3">
                <TextBlock Text="Derived prefix" Classes="muted" />
                <TextBox Text="{Binding DerivedSpeciesPrefix}" />
              </StackPanel>
              <StackPanel Grid.Row="2">
                <TextBlock Text="Realign window" Classes="muted" />
                <TextBox Text="{Binding LineageRealignParentMembershipWindow}" Width="112" />
              </StackPanel>
              <StackPanel Grid.Row="2" Grid.Column="1">
                <TextBlock Text="Realign margin" Classes="muted" />
                <TextBox Text="{Binding LineageRealignMatchMargin}" Width="84" />
              </StackPanel>
              <StackPanel Grid.Row="2" Grid.Column="2">
                <TextBlock Text="Hindsight window" Classes="muted" />
                <TextBox Text="{Binding LineageHindsightReassignCommitWindow}" Width="112" />
              </StackPanel>
              <StackPanel Grid.Row="2" Grid.Column="3">
                <TextBlock Text="Hindsight margin" Classes="muted" />
                <TextBox Text="{Binding LineageHindsightSimilarityMargin}" Width="84" />
              </StackPanel>
            </Grid>
            <CheckBox Content="Create derived species on divergence" IsChecked="{Binding CreateDerivedSpecies}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Apply Config" Classes="accent" Command="{Binding ApplyConfigCommand}" />
              <Button Content="{Binding StartNewEpochLabel}" Command="{Binding StartNewEpochCommand}" />
            </StackPanel>
            <TextBlock Text="{Binding ConfigStatus}" Classes="muted" TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </Grid>

      <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
        <Border Classes="card" Grid.Column="0">
          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBlock Text="Species Counts" Classes="card-title" />
              <TextBox Grid.Column="1" Width="110" Watermark="Epoch (blank=current)" Text="{Binding EpochFilterText}" />
            </Grid>
            <TextBlock Text="Membership counts refresh automatically for the selected epoch window." Classes="muted" TextWrapping="Wrap" />
            <ScrollViewer MaxHeight="280" HorizontalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding SpeciesCounts}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="row">
                      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <TextBlock Text="{Binding SpeciesDisplayName}" Classes="row-title" TextWrapping="Wrap" />
                        <TextBlock Grid.Column="1" Text="{Binding Count}" />
                        <TextBlock Grid.Column="2" Text="{Binding PercentLabel}" Classes="muted" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
            <TextBlock Text="{Binding HistoryStatus}" Classes="muted" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Classes="card" Grid.Column="1">
          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
              <TextBlock Text="Epoch Trend" Classes="card-title" />
              <TextBlock Grid.Column="1" Text="Chart window" Classes="muted" VerticalAlignment="Center" />
              <TextBox Grid.Column="2" Width="90" Watermark="0=all" Text="{Binding ChartWindowText}" />
            </Grid>
            <TextBlock Text="Recent-row trend window only; 0 uses all loaded history. The cladogram always uses the full loaded history." Classes="muted" TextWrapping="Wrap" />
            <TextBlock Text="{Binding CurrentEpochMaxDivergenceLabel}" Classes="muted" TextWrapping="Wrap" />
            <TextBlock Text="{Binding CurrentEpochSplitProximityLabel}" Classes="muted" TextWrapping="Wrap" />
            <ScrollViewer MaxHeight="280" HorizontalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding EpochSummaries}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="row">
                      <Grid ColumnDefinitions="Auto,Auto,Auto,*,*" ColumnSpacing="8">
                        <TextBlock Text="{Binding EpochId}" Classes="row-title" />
                        <TextBlock Grid.Column="1" Text="{Binding MembershipCount, StringFormat='memberships {0}'}" Classes="muted" />
                        <TextBlock Grid.Column="2" Text="{Binding SpeciesCount, StringFormat='species {0}'}" Classes="muted" />
                        <TextBlock Grid.Column="3" Text="{Binding FirstAssigned}" Classes="muted" />
                        <TextBlock Grid.Column="4" Text="{Binding LastAssigned}" Classes="muted" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </StackPanel>
        </Border>
      </Grid>

      <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
        <Border Classes="card" Grid.Column="0">
          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
              <TextBlock Text="Population Over Time" Classes="card-title" />
              <TextBlock Grid.Column="1" Text="Auto update" Classes="muted" VerticalAlignment="Center" />
              <Grid Grid.Column="2" ColumnDefinitions="Auto,Auto" ColumnSpacing="4">
                <TextBox Width="48" Text="{Binding LiveChartsIntervalSecondsText}" HorizontalContentAlignment="Center" />
                <TextBlock Grid.Column="1" Text="sec" Classes="muted" VerticalAlignment="Center" />
              </Grid>
            </Grid>
            <TextBlock Text="{Binding LiveChartsStatus}" Classes="muted" TextWrapping="Wrap" />
            <Grid ColumnDefinitions="44,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
              <Grid RowDefinitions="Auto,*,Auto">
                <TextBlock Text="{Binding PopulationChartYAxisTopLabel}" Classes="muted" FontSize="9" HorizontalAlignment="Right" />
                <TextBlock Grid.Row="1" Text="{Binding PopulationChartYAxisMidLabel}" Classes="muted" FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Center" />
                <TextBlock Grid.Row="2" Text="{Binding PopulationChartYAxisBottomLabel}" Classes="muted" FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
              </Grid>
              <Grid Grid.Column="1"
                    Width="{Binding PopulationChartWidth}"
                    Height="{Binding PopulationChartHeight}"
                    ClipToBounds="True">
                <shapes:Line StartPoint="0,8" EndPoint="360,8" Stroke="{DynamicResource NbnBorderBrush}" StrokeThickness="1" />
                <shapes:Line StartPoint="0,78" EndPoint="360,78" Stroke="{DynamicResource NbnBorderBrush}" StrokeThickness="1" />
                <shapes:Line StartPoint="0,148" EndPoint="360,148" Stroke="{DynamicResource NbnBorderBrush}" StrokeThickness="1" />
                <ItemsControl ItemsSource="{Binding PopulationChartSeries}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <Grid />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SpeciationLineChartSeriesItem">
                      <shapes:Path Data="{Binding PathData}" Stroke="{Binding Stroke}" StrokeThickness="1.7" IsHitTestVisible="False" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>
              <TextBlock Grid.Row="1"
                         Grid.Column="1"
                         Text="{Binding PopulationChartRangeLabel}"
                         Classes="muted"
                         FontSize="10"
                         TextWrapping="NoWrap"
                         TextTrimming="CharacterEllipsis" />
            </Grid>
            <TextBlock Text="{Binding PopulationChartMetricLabel}" Classes="muted" FontSize="10" TextWrapping="Wrap" />
            <ItemsControl ItemsSource="{Binding PopulationChartLegend}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Columns="{Binding $parent[UserControl].DataContext.PopulationChartLegendColumns}" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:SpeciationChartLegendItem">
                  <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,1,8,1">
                    <Border Width="12" Height="2" VerticalAlignment="Center" Background="{Binding Color}" />
                    <TextBlock Text="{Binding Label}" Classes="muted" FontSize="10" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Classes="card" Grid.Column="1">
          <StackPanel Spacing="8">
            <TextBlock Text="Species Flow (Epoch Top to Bottom)" Classes="card-title" />
            <TextBlock Text="Stacked widths show per-species population share over the loaded history window (full width = 100%). Left-axis ticks show epoch numbers, or row-sample positions when the window is a single sampled epoch." Classes="muted" TextWrapping="Wrap" />
            <Grid ColumnDefinitions="64,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,*,Auto" ColumnSpacing="6">
                <TextBlock Grid.RowSpan="3"
                           Text="time"
                           Classes="muted"
                           FontSize="9"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding FlowChartStartEpochLabel}" Classes="muted" FontSize="9" HorizontalAlignment="Right" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FlowChartMidEpochLabel}" Classes="muted" FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Center" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FlowChartEndEpochLabel}" Classes="muted" FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
              </Grid>
              <Grid Grid.Column="1"
                    Width="{Binding FlowChartWidth}"
                    Height="{Binding FlowChartHeight}"
                    ClipToBounds="True">
                <shapes:Line StartPoint="8,0" EndPoint="8,220" Stroke="{DynamicResource NbnBorderBrush}" StrokeThickness="1" />
                <shapes:Line StartPoint="180,0" EndPoint="180,220" Stroke="{DynamicResource NbnBorderBrush}" StrokeThickness="1" />
                <shapes:Line StartPoint="352,0" EndPoint="352,220" Stroke="{DynamicResource NbnBorderBrush}" StrokeThickness="1" />
                <ItemsControl ItemsSource="{Binding FlowChartAreas}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <Grid />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SpeciationFlowChartAreaItem">
                      <shapes:Path Data="{Binding PathData}" Fill="{Binding Fill}" StrokeThickness="0" IsHitTestVisible="False" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>
              <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                <TextBlock Text="0%" Classes="muted" FontSize="10" />
                <TextBlock Grid.Column="1" Text="50%" Classes="muted" FontSize="10" HorizontalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="100%" Classes="muted" FontSize="10" HorizontalAlignment="Right" />
              </Grid>
            </Grid>
            <TextBlock Text="{Binding FlowChartRangeLabel}" Classes="muted" FontSize="10" TextWrapping="Wrap" />
            <ItemsControl ItemsSource="{Binding FlowChartLegend}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Columns="{Binding $parent[UserControl].DataContext.FlowChartLegendColumns}" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:SpeciationChartLegendItem">
                  <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,1,8,1">
                    <Border Width="12" Height="10" VerticalAlignment="Center" Background="{Binding Color}" />
                    <TextBlock Text="{Binding Label}" Classes="muted" FontSize="10" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </Grid>

      <Border Classes="card">
        <StackPanel Spacing="8">
          <TextBlock Text="Split Proximity Trend" Classes="card-title" />
          <TextBlock Text="Most recent species with split-proximity samples. Values track min source-species similarity minus effective split threshold (0 = split cutoff, below 0 = crossed)." Classes="muted" TextWrapping="Wrap" />
          <Grid ColumnDefinitions="44,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
            <Grid RowDefinitions="Auto,*,Auto">
              <TextBlock Text="{Binding SplitProximityChartYAxisTopLabel}" Classes="muted" FontSize="9" HorizontalAlignment="Right" />
              <TextBlock Grid.Row="1" Text="{Binding SplitProximityChartYAxisMidLabel}" Classes="muted" FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Center" />
              <TextBlock Grid.Row="2" Text="{Binding SplitProximityChartYAxisBottomLabel}" Classes="muted" FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
            </Grid>
            <Grid Grid.Column="1"
                  Width="{Binding PopulationChartWidth}"
                  Height="{Binding PopulationChartHeight}"
                  ClipToBounds="True">
              <shapes:Line StartPoint="0,8" EndPoint="360,8" Stroke="{DynamicResource NbnBorderBrush}" StrokeThickness="1" />
              <shapes:Line StartPoint="0,78" EndPoint="360,78" Stroke="{DynamicResource NbnBorderBrush}" StrokeThickness="1" />
              <shapes:Line StartPoint="0,148" EndPoint="360,148" Stroke="{DynamicResource NbnBorderBrush}" StrokeThickness="1" />
              <ItemsControl ItemsSource="{Binding SplitProximityChartSeries}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <Grid />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:SpeciationLineChartSeriesItem">
                    <shapes:Path Data="{Binding PathData}" Stroke="{Binding Stroke}" StrokeThickness="1.7" IsHitTestVisible="False" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Grid>
            <TextBlock Grid.Row="1"
                       Grid.Column="1"
                       Text="{Binding SplitProximityChartRangeLabel}"
                       Classes="muted"
                       FontSize="10"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis" />
          </Grid>
          <TextBlock Text="{Binding SplitProximityChartMetricLabel}" Classes="muted" FontSize="10" TextWrapping="Wrap" />
          <ItemsControl ItemsSource="{Binding SplitProximityChartLegend}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Columns="{Binding $parent[UserControl].DataContext.SplitProximityChartLegendColumns}" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:SpeciationChartLegendItem">
                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,1,8,1">
                  <Border Width="12" Height="2" VerticalAlignment="Center" Background="{Binding Color}" />
                  <TextBlock Text="{Binding Label}" Classes="muted" FontSize="10" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="8">
          <TextBlock Text="Species Cladogram" Classes="card-title" />
          <TextBlock Text="{Binding CladogramMetricLabel}" Classes="muted" TextWrapping="Wrap" />
          <TextBlock Text="{Binding CladogramRangeLabel}" Classes="muted" FontSize="10" TextWrapping="Wrap" />
          <Border Classes="row">
            <TextBlock Text="{Binding CladogramKeyLabel}" Classes="muted" FontSize="10" TextWrapping="Wrap" />
          </Border>
          <ScrollViewer MaxHeight="260" HorizontalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding CladogramItems}" ItemTemplate="{StaticResource CladogramNodeTemplate}" />
          </ScrollViewer>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="8">
          <TextBlock Text="Reproduction Simulator" Classes="card-title" />
          <TextBlock Text="Standalone EvolutionSim controls for stress runs using two primary live parent brains plus optional extra seed parents. Parent A/B auto-seed from the selected live brains, override files replace those slots, and extras append to the effective pool." Classes="muted" TextWrapping="Wrap" />

          <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
            <StackPanel>
              <TextBlock Text="Bind host" Classes="muted" />
              <TextBox Width="130" Text="{Binding SimBindHost}" />
            </StackPanel>
            <StackPanel Grid.Column="1">
              <TextBlock Text="Port" Classes="muted" />
              <TextBox Width="90" Text="{Binding SimPortText}" />
            </StackPanel>
            <StackPanel Grid.Column="2">
              <TextBlock Text="Seed" Classes="muted" />
              <TextBox Width="110" Text="{Binding SimSeedText}" />
            </StackPanel>
            <StackPanel Grid.Column="3">
              <TextBlock Text="Interval ms" Classes="muted" />
              <TextBox Width="90" Text="{Binding SimIntervalMsText}" />
            </StackPanel>
            <StackPanel Grid.Column="4">
              <TextBlock Text="Min runs" Classes="muted" />
              <TextBox Width="80" Text="{Binding SimMinRunsText}" />
            </StackPanel>
            <StackPanel Grid.Column="5">
              <TextBlock Text="Max runs" Classes="muted" />
              <TextBox Width="80" Text="{Binding SimMaxRunsText}" />
            </StackPanel>

            <StackPanel Grid.Row="1">
              <TextBlock Text="Gamma" Classes="muted" />
              <TextBox Width="90" Text="{Binding SimGammaText}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1">
              <TextBlock Text="Status sec" Classes="muted" />
              <TextBox Width="90" Text="{Binding SimStatusSecondsText}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="2">
              <TextBlock Text="Timeout sec" Classes="muted" />
              <TextBox Width="90" Text="{Binding SimTimeoutSecondsText}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="3">
              <TextBlock Text="Max iterations" Classes="muted" />
              <TextBox Width="110" Text="{Binding SimMaxIterationsText}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="4">
              <TextBlock Text="Max pool" Classes="muted" />
              <TextBox Width="90" Text="{Binding SimMaxParentPoolText}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="5" Orientation="Vertical" Spacing="2">
              <CheckBox Content="Commit to speciation" IsChecked="{Binding SimCommitToSpeciation}" />
              <CheckBox Content="Spawn children" IsChecked="{Binding SimSpawnChildren}" />
            </StackPanel>

            <StackPanel Grid.Row="2">
              <TextBlock Text="Run pressure" Classes="muted" />
              <ComboBox Width="140"
                        ItemsSource="{Binding SimRunPressureModes}"
                        SelectedItem="{Binding SimRunPressureMode}" />
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="1">
              <TextBlock Text="Parent bias" Classes="muted" />
              <ComboBox Width="140"
                        ItemsSource="{Binding SimParentSelectionBiasModes}"
                        SelectedItem="{Binding SimParentSelectionBias}" />
            </StackPanel>
          </Grid>

          <TextBlock Text="Run pressure mode: divergence (more exploratory run counts), neutral, or stability (more conservative run counts)."
                     Classes="muted"
                     TextWrapping="Wrap" />
          <TextBlock Text="Parent bias mode: divergence favors newer parents in the pool, stability favors older parents, neutral keeps uniform random selection."
                     Classes="muted"
                     TextWrapping="Wrap" />

          <TextBlock Text="Parent A/B auto-populate from the selected active brains. Optional override files replace those slots, and extra parents append to the same effective pool."
                     Classes="muted"
                     TextWrapping="Wrap" />

          <Grid ColumnDefinitions="Auto,*,Auto,*"
                RowDefinitions="Auto,Auto"
                ColumnSpacing="10"
                RowSpacing="6">
            <TextBlock Text="Parent A" Classes="muted" />
            <ComboBox Grid.Column="1" ItemsSource="{Binding SimActiveBrains}" SelectedItem="{Binding SimSelectedParentABrain}" Width="300">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Grid.Column="2" Text="Parent B" Classes="muted" />
            <ComboBox Grid.Column="3" ItemsSource="{Binding SimActiveBrains}" SelectedItem="{Binding SimSelectedParentBBrain}" Width="300">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>

          <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                RowDefinitions="Auto,Auto"
                ColumnSpacing="10"
                RowSpacing="6">
            <TextBlock Text="Extra parent" Classes="muted" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding SimActiveBrains}"
                      SelectedItem="{Binding SimExtraParentCandidateBrain}"
                      Width="300">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Column="2" Content="Add" Command="{Binding AddSimSeedParentCommand}" />
            <Button Grid.Column="3" Content="Add All" Command="{Binding AddAllSimSeedParentsCommand}" />
            <Button Grid.Column="4" Content="Add From File" Command="{Binding AddSimSeedParentsFromFileCommand}" />

            <TextBlock Grid.Row="1" Text="Seed parents" Classes="muted" />
            <Border Grid.Row="1" Grid.Column="1" Classes="row">
              <TextBlock Text="{Binding SimSeedParentsSummary}" Classes="muted" />
            </Border>
            <Button Grid.Row="1" Grid.Column="2" Content="Clear Extras" Command="{Binding ClearSimSeedParentsCommand}" />
            <TextBlock Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="2"
                       Text="Requires 2+ distinct total parents to start."
                       Classes="muted"
                       VerticalAlignment="Center" />
          </Grid>

          <ScrollViewer MaxHeight="100" HorizontalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding SimSeedParents}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:SpeciationSimulatorSeedParentItem">
                  <Border Classes="row">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                      <TextBlock Text="{Binding BrainIdLabel}" Classes="row-title" />
                      <TextBlock Grid.Column="1" Text="{Binding Label}" Classes="muted" />
                      <TextBlock Grid.Column="2" Text="{Binding Source}" Classes="muted" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <Grid ColumnDefinitions="Auto,*,Auto,*"
                RowDefinitions="Auto,Auto"
                ColumnSpacing="10"
                RowSpacing="6">
            <TextBlock Text="Parent A file" Classes="muted" />
            <Border Grid.Column="1" Classes="row">
              <TextBlock Text="{Binding SimParentAOverrideFilePathDisplay}" Classes="muted" TextWrapping="Wrap" />
            </Border>
            <Button Grid.Column="2" Content="Browse" Command="{Binding BrowseSimParentAOverrideFileCommand}" />
            <TextBlock Grid.Column="3" Text="Optional GUID file override" Classes="muted" VerticalAlignment="Center" />

            <TextBlock Grid.Row="1" Text="Parent B file" Classes="muted" />
            <Border Grid.Row="1" Grid.Column="1" Classes="row">
              <TextBlock Text="{Binding SimParentBOverrideFilePathDisplay}" Classes="muted" TextWrapping="Wrap" />
            </Border>
            <Button Grid.Row="1" Grid.Column="2" Content="Browse" Command="{Binding BrowseSimParentBOverrideFileCommand}" />
            <TextBlock Grid.Row="1" Grid.Column="3" Text="Optional GUID file override" Classes="muted" VerticalAlignment="Center" />
          </Grid>

          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
            <TextBlock Text="Notes"
                       Classes="muted"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="1"
                       Text="Simulator sends one --parent-brain value per distinct live parent brain. Parent A/B are seeded automatically, override file(s) take precedence for those slots, and extras append."
                       Classes="muted"
                       TextWrapping="Wrap" />
          </Grid>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Start Simulator" Classes="accent" Command="{Binding StartSimulatorCommand}" />
            <Button Content="Stop Simulator" Command="{Binding StopSimulatorCommand}" />
          </StackPanel>

          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="4">
            <TextBlock Text="Runner" Classes="muted" />
            <TextBlock Grid.Column="1" Text="{Binding SimulatorStatus}" Classes="muted" TextWrapping="Wrap" />
            <TextBlock Grid.Row="1" Text="Session" Classes="muted" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SimulatorSessionId}" Classes="row-title" TextWrapping="Wrap" />
            <TextBlock Grid.Row="2" Text="Progress" Classes="muted" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SimulatorProgress}" Classes="muted" TextWrapping="Wrap" />
            <TextBlock Grid.Row="3" Text="Stats" Classes="muted" />
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SimulatorDetailedStats}" Classes="muted" TextWrapping="Wrap" />
            <TextBlock Grid.Row="4" Text="Last failure" Classes="muted" />
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SimulatorLastFailure}" Classes="muted" TextWrapping="Wrap" />
          </Grid>
        </StackPanel>
      </Border>

      <TextBlock Text="{Binding Status}" Classes="muted" TextWrapping="Wrap" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
