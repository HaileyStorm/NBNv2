#!/usr/bin/env sh
set -eu

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$REPO_ROOT"

detect_docs_platform() {
    case "${OS-}" in
        Windows_NT)
            echo windows
            return 0
            ;;
    esac

    case "${OSTYPE-}" in
        msys*|cygwin*|win32*)
            echo windows
            return 0
            ;;
        linux*|darwin*)
            echo posix
            return 0
            ;;
    esac

    os_name="$(uname -s 2>/dev/null || printf 'unknown')"
    case "$os_name" in
        Windows_NT|MINGW*|MSYS*|CYGWIN*)
            echo windows
            ;;
        Linux|Darwin)
            echo posix
            ;;
        *)
            echo "error: unsupported hook platform '$os_name'; run the docs freshness check manually for this OS." >&2
            return 1
            ;;
    esac
}

run_docs_check() {
    platform="$(detect_docs_platform)"

    case "$platform" in
        windows)
            if ! command -v powershell.exe >/dev/null 2>&1; then
                echo "error: powershell.exe is required to validate docs on Windows." >&2
                exit 1
            fi
            powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./tools/docs/render-nbnv2-docs.ps1 -Check
            ;;
        posix)
            if ! command -v bash >/dev/null 2>&1; then
                echo "error: bash is required to validate docs on Linux/macOS." >&2
                exit 1
            fi
            bash ./tools/docs/render-nbnv2-docs.sh --check
            ;;
    esac
}

run_docs_check
